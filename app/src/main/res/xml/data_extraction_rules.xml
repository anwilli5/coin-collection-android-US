<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup/transfer rules for Android 12 (API 31) and higher. This is the
   modern replacement for @xml/backup_descriptor (android:fullBackupContent),
   which is still used on older platform versions.

   All databases and preferences are fine to preserve, and do not contain any
   device-specific or sensitive information, so everything is included by
   default for both cloud backups and device-to-device transfers.
-->
<data-extraction-rules>
    <cloud-backup />
    <device-transfer />
</data-extraction-rules>
